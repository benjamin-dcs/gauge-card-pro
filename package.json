{
  "name": "gauge-card-pro",
  "version": "2.4.10",
  "description": "Gauge Card Pro",
  "main": "index.js",
  "scripts": {
    "start:watch": "rolldown -c --watch",
    "build": "rolldown -c",
    "depcheck": "depcheck --ignores='eslint'",
    "format": "prettier --write --list-different .",
    "pull:hass-old": "docker pull homeassistant/home-assistant:2026.1.0",
    "pull:hass-stable": "docker pull homeassistant/home-assistant:stable",
    "pull:hass": "docker pull homeassistant/home-assistant:beta",
    "start:hass-old": "docker run --rm -p8123:8123 -v ./.hass_dev:/config homeassistant/home-assistant:2026.1.0",
    "start:hass-stable": "docker run --rm -p8123:8123 -v ./.hass_dev:/config homeassistant/home-assistant:stable",
    "start:hass": "docker run --rm -p8123:8123 -v ./.hass_dev:/config homeassistant/home-assistant:beta",
    "start:hass-dev": "docker run --rm -p8123:8123 -v ./.hass_dev:/config homeassistant/home-assistant:dev",
    "bench": "vitest bench",
    "test": "vitest run --silent"
  },
  "author": "Benjamin DCS",
  "repository": {
    "type": "git",
    "url": "https://github.com/benjamin-dcs/gauge-card-pro"
  },
  "license": "ISC",
  "dependencies": {
    "@mdi/js": "7.4.47",
    "home-assistant-js-websocket": "9.6.0",
    "lit": "3.3.2",
    "memoize-one": "6.0.0",
    "object-hash": "3.0.0",
    "superstruct": "2.0.2",
    "tinygradient": "2.0.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/css": "1.1.0",
    "@eslint/js": "10.0.1",
    "@eslint/json": "1.2.0",
    "depcheck": "1.4.7",
    "eslint": "10.2.0",
    "globals": "17.4.0",
    "jiti": "2.6.1",
    "prettier": "3.8.1",
    "rolldown": "1.0.0-rc.13",
    "rollup-plugin-serve": "1.1.1",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.0",
    "vitest": "4.1.3"
  }
}
